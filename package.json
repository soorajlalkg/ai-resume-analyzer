{
  "name": "user-management-api",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typeorm": "tsx ./node_modules/typeorm/cli.js",
    "migration:generate": "npx tsx src/database/cli/migration-create.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/data-source.ts",
    "migrate:up": "npm run migration:run",
    "migrate:down": "npm run migration:revert",
    "migration:run:prod": "typeorm migration:run -d dist/data-source.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1064.0",
    "@aws-sdk/client-ses": "^3.1064.0",
    "@aws-sdk/s3-request-presigner": "^3.1065.0",
    "@langchain/openai": "^1.4.7",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "helmet": "^8.2.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.4.5",
    "morgan": "^1.11.0",
    "openai": "^6.42.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.21.0",
    "qdrant-client": "^0.0.1",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-fileupload": "^1.5.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^6.0.3"
  }
}
